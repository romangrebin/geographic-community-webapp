NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — server-side only, never NEXT_PUBLIC. Used for DB writes so RLS
# doesn't block server-side operations (ownership is enforced at the API route layer).
# Find it in Supabase dashboard → Project Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional: tile provider (Protomaps, Stadia, etc.)
NEXT_PUBLIC_MAPTILER_KEY=
# Optional: ntfy push notification URL for new reports.
# Include the topic in the URL, e.g. https://ntfy.sh/your-secret-topic
# Use a hard-to-guess topic name since there's no auth by default.
NTFY_URL=
